# This site needs NO environment variables to build, run, or deploy.
#
# Editable config lives in src/lib/siteConfig.ts:
#   - web3formsAccessKey  → the Web3Forms key (public, send-only) the contact form posts to
#   - url / domain        → the canonical site URL used for SEO / og:url
#
# Change those values there; there is nothing to put in a .env file.
