# Web3Forms access key (PUBLIC submission key — safe in the client bundle, can be committed).
# Get one free at https://web3forms.com → used by the Phase 3 contact form.
VITE_WEB3FORMS_KEY=

# Canonical site URL (used for SEO / og:url). Change once the real domain is set.
VITE_SITE_URL=https://standleytech.com

# Optional hCaptcha site key (enable in the Web3Forms dashboard for spam protection).
VITE_HCAPTCHA_SITEKEY=
